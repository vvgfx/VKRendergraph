// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug engine",
    "build": {
      "command": "/bin/bash",
      "args": [
        "-c",
        "cmake --build build --target Shaders && cmake --build build --target engine",
      ],
      "cwd": "$ZED_WORKTREE_ROOT",
    },
    "program": "$ZED_WORKTREE_ROOT/bin/engine",
    "request": "launch",
    "cwd": "$ZED_WORKTREE_ROOT/bin",
    "adapter": "CodeLLDB",
  },
]
